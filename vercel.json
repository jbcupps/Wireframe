{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30,
      "excludeFiles": "{.github/**,docs/**,scripts/**,tests/**,**/__pycache__/**,*.md,Dockerfile,docker-compose.yml,Makefile,playwright.config.py,pytest.ini,requirements-dev.txt}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
